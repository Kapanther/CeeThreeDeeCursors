{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/CeeThreeDeeCursors/CeeThreeDeeCursors.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/CeeThreeDeeCursors/CeeThreeDeeCursors.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/CeeThreeDeeCursors/CeeThreeDeeCursors.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-installer",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/build-installer.ps1",
                "-Configuration",
                "Release"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "version-bump-patch",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/bump-version.ps1",
                "-Part",
                "patch"
            ]
        },
        {
            "label": "version-bump-minor",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/bump-version.ps1",
                "-Part",
                "minor"
            ]
        },
        {
            "label": "version-bump-major",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/bump-version.ps1",
                "-Part",
                "major"
            ]
        },
        {
            "label": "release-dispatch",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/trigger-release.ps1",
                "-Ref",
                "main"
            ]
        },
        {
            "label": "release-local",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/release-local.ps1",
                "-Configuration",
                "Release"
            ]
        }
    ]
}